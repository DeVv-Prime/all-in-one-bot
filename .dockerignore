FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    ffmpeg \
    git \
    gcc \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

# Upgrade pip and install tools
RUN pip install --upgrade pip setuptools wheel

# Copy requirements first (for better caching)
COPY requirements.txt .

# Install dependencies one by one to identify issues
RUN pip install --no-cache-dir discord.py==2.3.2 && \
    pip install --no-cache-dir wavelink==3.2.0 && \
    pip install --no-cache-dir yt-dlp==2024.12.13 && \
    pip install --no-cache-dir spotipy==2.23.0 && \
    pip install --no-cache-dir aiosqlite==0.19.0 && \
    pip install --no-cache-dir flask==3.0.0 && \
    pip install --no-cache-dir aiohttp==3.9.1 && \
    pip install --no-cache-dir python-dotenv==1.0.0 && \
    pip install --no-cache-dir psutil==5.9.6 && \
    pip install --no-cache-dir humanize==4.9.0 && \
    pip install --no-cache-dir aiofiles==23.2.1 && \
    pip install --no-cache-dir Pillow==10.1.0 && \
    pip install --no-cache-dir requests==2.31.0 && \
    pip install --no-cache-dir emoji==2.8.0 && \
    pip install --no-cache-dir asyncio==3.4.3

# Copy bot files
COPY . .

# Run bot
CMD ["python", "main.py"]
